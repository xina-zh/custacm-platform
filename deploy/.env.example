COMPOSE_PROJECT_NAME=custacm-platform-blog

BLOG_DB_VOLUME_NAME=custacm-platform_blog-db-data
BLOG_REDIS_VOLUME_NAME=custacm-platform_blog-redis-data
BLOG_DB_NAME=custacm_blog
BLOG_DB_USERNAME=custacm_blog
BLOG_DB_PASSWORD=change-me-blog-db-password
BLOG_DB_ROOT_PASSWORD=change-me-blog-root-password

BACKEND_PORT=8090
FRONTEND_PORT=3000
FRONTEND_HTTPS_PORT=3443
TLS_ENABLED=false
TLS_CERT_DIR=./secrets/tls
FRONTEND_IMAGE_REFERER_HOSTS=custacm.top
FRONTEND_ALLOW_LOCAL_REFERERS=true
BLOG_TOKEN_SECRET=change-me-with-at-least-sixty-four-characters-for-hs512-signing-key-2026
BLOG_TOKEN_TTL_MILLIS=259200000
BLOG_BOOTSTRAP_ADMIN_PASSWORD=change-me-bootstrap-admin-password
BLOG_CACHE_TTL=10m

# 自动采集默认全部关闭；启用后每日回看 100h，日内任务从上次游标直接续爬。
# 仅在确认外部 API 配额与服务器负载后按需开启。
BLOG_DAILY_COLLECTION_LOOKBACK=100h
BLOG_INTRADAY_COLLECTION_LOOKBACK=0h
BLOG_CODEFORCES_DAILY_COLLECTION_ENABLED=false
BLOG_CODEFORCES_INTRADAY_COLLECTION_ENABLED=false
BLOG_ATCODER_DAILY_COLLECTION_ENABLED=false
BLOG_ATCODER_INTRADAY_COLLECTION_ENABLED=false
BLOG_ATCODER_PROBLEM_LIST_SCHEDULE_ENABLED=false
BLOG_ATCODER_PROBLEM_LIST_BOOTSTRAP_ENABLED=false
