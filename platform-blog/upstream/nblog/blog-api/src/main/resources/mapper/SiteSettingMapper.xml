<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="top.naccl.mapper.SiteSettingMapper">

    <!--只查询公开页面仍在消费的配置-->
    <select id="getPublicSiteInfoList" resultType="top.naccl.entity.SiteSetting">
        select name_en, value
        from site_setting
        where name_en in ('reward', 'commentAdminFlag', 'avatar', 'name')
    </select>
</mapper>
