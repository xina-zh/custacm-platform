<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="top.naccl.mapper.TagMapper">

    <resultMap id="tag" type="top.naccl.entity.Tag">
        <id property="id" column="id"/>
        <result property="name" column="tag_name"/>
        <result property="color" column="color"/>
    </resultMap>

    <!--获取所有标签List-->
    <select id="getTagList" resultMap="tag">
        select id, tag_name, color from tag order by id desc
    </select>

    <!--获取所有标签List不查询id-->
    <select id="getTagListNotId" resultMap="tag">
        select tag_name, color from tag order by id desc
    </select>

    <resultMap id="blogTagProjection" type="top.naccl.model.vo.BlogTagProjection">
        <id property="blogId" column="blog_id"/>
        <id property="tagId" column="tag_id"/>
        <result property="tagName" column="tag_name"/>
        <result property="color" column="color"/>
    </resultMap>

    <!--按当前文章页一次批量查询标签，避免逐文章查询-->
    <select id="getTagListByBlogIds" resultMap="blogTagProjection">
        select bt.blog_id, t.id as tag_id, t.tag_name, t.color
        from blog_tag as bt
        inner join tag as t on bt.tag_id = t.id
        where bt.blog_id in
        <foreach collection="collection" item="blogId" open="(" separator="," close=")">
            #{blogId}
        </foreach>
        order by bt.blog_id, t.id
    </select>

    <!--添加标签-->
    <insert id="saveTag" parameterType="top.naccl.entity.Tag" useGeneratedKeys="true" keyProperty="id">
        insert into tag (tag_name, color) values (#{name}, #{color})
    </insert>

    <!--按id查询标签-->
    <select id="getTagById" resultMap="tag">
        select id, tag_name, color from tag where id=#{id}
    </select>

    <!--按id删除标签-->
    <delete id="deleteTagById">
        delete from tag where id=#{id}
    </delete>

</mapper>
